{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ebooknook",
  "version": "0.1.0",
  "identifier": "luckmer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "veloflow",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' 'unsafe-inline' blob: data: asset: http://asset.localhost ipc: http://ipc.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost asset: http://asset.localhost blob:",
        "img-src": "'self' blob: data: asset: http://asset.localhost https://asset.localhost",
        "style-src": "'self' 'unsafe-inline' blob: asset: http://asset.localhost",
        "style-src-elem": "'self' 'unsafe-inline' blob: asset: http://asset.localhost",
        "font-src": "'self' blob: data: asset: http://asset.localhost",
        "frame-src": "'self' blob: asset: http://asset.localhost",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' blob: asset: http://asset.localhost"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "C:/Users/**",
            "$APPDATA/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "/**"
          ],
          "deny": []
        }
      },
      "capabilities": [
        "default",
        {
          "identifier": "draggable-window",
          "windows": [
            "*"
          ],
          "permissions": [
            "core:window:allow-start-dragging",
            "core:window:allow-toggle-maximize",
            "core:window:allow-internal-toggle-maximize",
            "core:window:allow-close",
            "core:window:allow-minimize",
            "fs:allow-remove",
            "fs:allow-copy-file",
            "fs:allow-mkdir",
            "fs:allow-exists",
            "fs:allow-read-file",
            "fs:allow-write-file",
            {
              "identifier": "fs:scope",
              "allow": [
                {
                  "path": "$APPDATA/**"
                },
                {
                  "path": "$DOCUMENT/**"
                },
                {
                  "path": "$DOWNLOAD/**"
                }
              ]
            },
            {
              "identifier": "fs:allow-read",
              "allow": [
                {
                  "path": "$APPDATA/**"
                },
                {
                  "path": "$DOCUMENT/**"
                },
                {
                  "path": "$DOWNLOAD/**"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}